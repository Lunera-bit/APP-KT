    <!-- Kotlin stdlib and compiler - build-time only, not shipped in APK -->
    <suppress>
        <notes>Kotlin stdlib and compiler dependencies. CVE-2026-53914 and CVE-2020-29582 affect the compiler/IDE plugin, not the runtime. CVE-2025-29903 affects parcelize plugin. Build-time only.</notes>
        <filePath regex="true">.*kotlin-.*\.jar</filePath>
        <cve>CVE-2026-53914</cve>
        <cve>CVE-2020-29582</cve>
        <cve>CVE-2025-29903</cve>
    </suppress>

