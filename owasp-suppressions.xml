    <!-- Kotlin stdlib and compiler - build-time only, not shipped in APK -->
    <suppress>
        <notes>Kotlin stdlib and compiler dependencies. CVE-2026-53914 and CVE-2020-29582 affect the compiler/IDE plugin, not the runtime. CVE-2025-29903 affects parcelize plugin. Build-time only, not shipped in production APK.</notes>
        <filePath regex="true">.*kotlin-.*\.jar</filePath>
        <cve>CVE-2026-53914</cve>
        <cve>CVE-2020-29582</cve>
        <cve>CVE-2025-29903</cve>
    </suppress>

    <!-- Guava - transitive via Firebase/gRPC -->
    <suppress>
        <notes>Guava is a transitive dependency of Firebase/gRPC. CVE-2023-2976 is about temp directory permissions (low risk on Android). CVE-2020-8908 is about File.createTempFile (CVSS 3.3).</notes>
        <filePath regex="true">.*guava.*\.jar</filePath>
        <cve>CVE-2023-2976</cve>
        <cve>CVE-2020-8908</cve>
    </suppress>

    <!-- kotlinx-coroutines-play-services - build-time/runtime bridge -->
    <suppress>
        <notes>kotlinx-coroutines-play-services is a coroutine wrapper for Play Services Tasks. CVE-2020-22475 and CVE-2022-39349 affect older coroutines internals, mitigated by version 1.8.1.</notes>
        <filePath regex="true">.*kotlinx-coroutines-play-services.*\.jar</filePath>
        <cve>CVE-2020-22475</cve>
        <cve>CVE-2022-39349</cve>
    </suppress>

    <!-- room-compiler-processing - kapt build-time only -->
    <suppress>
        <notes>Room compiler processing is a build-time annotation processor, not included in the APK. CVE-2018-1000840 affects JAR archive handling in build tools.</notes>
        <filePath regex="true">.*room-compiler-processing.*\.jar</filePath>
        <cve>CVE-2018-1000840</cve>
    </suppress>

    <!-- symbol-processing-api - Kotlin compiler plugin, build-time only -->
    <suppress>
        <notes>KSP symbol-processing-api is a build-time Kotlin compiler plugin, not included in the APK. CVE-2018-1000840 affects JAR archive handling.</notes>
        <filePath regex="true">.*symbol-processing-api.*\.jar</filePath>
        <cve>CVE-2018-1000840</cve>
    </suppress>

